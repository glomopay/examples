@{
    ViewData["Title"] = "Home";
}

<div class="product-container">
    <div class="product-card">
        <div class="product-image">
            <svg width="120" height="120" viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect width="120" height="120" rx="16" fill="#f0f0f0"/>
                <path d="M60 30L90 75H30L60 30Z" fill="#6366f1"/>
                <circle cx="60" cy="70" r="20" fill="#8b5cf6"/>
            </svg>
        </div>
        <h2 class="product-name">Demo Product</h2>
        <p class="product-description">
            A sample product to demonstrate Glomo Checkout SDK integration.
        </p>
        <p class="product-price">$10.00 USD</p>
        <form asp-controller="Payment" asp-action="Checkout" method="post">
            <button type="submit" class="buy-button">Buy Now</button>
        </form>
    </div>
</div>

<div class="info-section">
    <h3>How This Works</h3>
    <ol>
        <li>Click "Buy Now" to initiate checkout</li>
        <li>Server creates an order via Glomo API</li>
        <li>Glomo Checkout SDK opens in a modal</li>
        <li>Complete the payment</li>
        <li>Get redirected to success/failure page</li>
    </ol>
</div>
