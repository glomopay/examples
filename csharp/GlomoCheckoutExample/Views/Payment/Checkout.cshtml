@model CheckoutViewModel
@{
    ViewData["Title"] = "Checkout";
}

<div class="checkout-container">
    <div class="checkout-card">
        <h2>Processing Your Order</h2>
        <p class="order-info">
            <strong>@Model.ProductName</strong><br />
            @Model.Amount.ToString("C") @Model.Currency
        </p>
        <p class="checkout-message">Please complete your payment in the popup window.</p>
        <div class="loading-spinner"></div>
    </div>
</div>

@section Scripts {
<script type="module">
    import { GlomoCheckoutApi } from 'https://glomopay-checkout-sdk.web.app/index.js';

    const checkout = new GlomoCheckoutApi({
        orderId: '@Model.OrderId',
        publicKey: '@Model.PublicKey'
    });

    // Open checkout immediately
    checkout.open();

    checkout.on('payment.success', function(response) {
        console.log('Payment successful:', response);
        fetch('/Payment/HandlePaymentResponse', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(response)
        })
        .then(res => res.json())
        .then(data => {
            if (data.redirectUrl) {
                window.location.href = data.redirectUrl;
            }
        })
        .catch(error => {
            console.error('Error handling payment response:', error);
            window.location.href = '/Payment/Failure?error=' + encodeURIComponent('Failed to process payment response');
        });
    });

    checkout.on('payment.failure', function(response) {
        console.log('Payment failed:', response);
        fetch('/Payment/HandlePaymentResponse', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(response)
        })
        .then(res => res.json())
        .then(data => {
            if (data.redirectUrl) {
                window.location.href = data.redirectUrl;
            }
        })
        .catch(error => {
            console.error('Error handling payment response:', error);
            window.location.href = '/Payment/Failure?error=' + encodeURIComponent(response.error_message || 'Payment failed');
        });
    });

    checkout.on('checkout.closed', function() {
        console.log('Checkout closed by user');
        window.location.href = '/';
    });
</script>
}
