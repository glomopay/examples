@model PaymentResultViewModel
@{
    ViewData["Title"] = "Payment Failed";
}

<div class="result-container">
    <div class="result-card failure">
        <div class="result-icon">
            <svg width="64" height="64" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="32" cy="32" r="32" fill="#ef4444"/>
                <path d="M24 24L40 40M40 24L24 40" stroke="white" stroke-width="4" stroke-linecap="round"/>
            </svg>
        </div>
        <h2>Payment Failed</h2>
        <p>We couldn't process your payment.</p>

        <div class="error-details">
            @if (!string.IsNullOrEmpty(Model.ErrorCode))
            {
                <div class="detail-row">
                    <span class="label">Error Code:</span>
                    <span class="value">@Model.ErrorCode</span>
                </div>
            }
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="detail-row">
                    <span class="label">Error:</span>
                    <span class="value">@Model.ErrorMessage</span>
                </div>
            }
        </div>

        <div class="button-group">
            <a href="/" class="button">Try Again</a>
            <a href="/" class="button secondary">Return to Home</a>
        </div>
    </div>
</div>
