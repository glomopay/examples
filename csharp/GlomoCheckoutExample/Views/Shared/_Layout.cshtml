<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Glomo Checkout Example</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <header>
        <nav>
            <a href="/" class="logo">Glomo Checkout Example</a>
        </nav>
    </header>

    <main>
        @RenderBody()
    </main>

    <footer>
        <p>This is an example integration for demonstration purposes only.</p>
        <p>
            <a href="https://docs.glomopay.com/product-guide/payin/checkout" target="_blank">
                View Documentation
            </a>
        </p>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
